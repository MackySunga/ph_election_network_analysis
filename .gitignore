# Raw datasets are intentionally excluded from GitHub
# Place them manually in data/raw/ after cloning/forking.
data/raw/*
!data/raw/.gitkeep
!data/raw/README_PLACE_RAW_DATA_HERE.md

# Generated analysis outputs are intentionally excluded.
data/processed/*
!data/processed/.gitkeep
!data/processed/README_GENERATED.md

outputs/**
!outputs/
!outputs/.gitkeep
!outputs/README_GENERATED.md
!outputs/figures/
!outputs/figures/.gitkeep
!outputs/interactive/
!outputs/interactive/.gitkeep
!outputs/tables/
!outputs/tables/.gitkeep
!outputs/networks/
!outputs/networks/.gitkeep
!outputs/report_assets/
!outputs/report_assets/.gitkeep
!outputs/run_logs/
!outputs/run_logs/.gitkeep
!outputs/executed_notebooks/
!outputs/executed_notebooks/.gitkeep

